{
  "manifest_version": 3,
  "name": "Screenshot Pro",
  "version": "1.0.0",
  "description": "Clean, modern screenshot tool. Capture visible screen, full page, or selected area.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "downloads",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Screenshot Pro",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
